# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- SimPro ---
# Tenant subdomain only, e.g. "optdigital" if your URL is optdigital.simprosuite.com
SIMPRO_TENANT=
# Token was provided in the original brief — paste into .env.local, NOT here.
# .env.example is committed; .env.local is gitignored.
SIMPRO_ACCESS_TOKEN=
# Company ID inside SimPro (usually 0 for the default company, or the numeric ID from /companies/)
SIMPRO_COMPANY_ID=0

# --- WhatConverts ---
# Basic Auth: api_token:api_secret
WC_API_TOKEN=
WC_API_SECRET=
# Comma-separated profile IDs: FlowPro + "A Plumber Near Me"
WC_PROFILE_IDS=

# --- Google Ads (stubbed, fill when ready) ---
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# --- Meta Ads (stubbed, fill when ready) ---
META_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=

# --- Office origin ---
# Used for "how far from office" distance calculations
OFFICE_ADDRESS=Silverdale, Auckland, New Zealand
OFFICE_LAT=-36.6203
OFFICE_LNG=174.6707

# --- Cron security ---
CRON_SECRET=
